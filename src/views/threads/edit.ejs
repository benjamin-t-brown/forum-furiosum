<%- include('../partials/layout-top', { title: title }) %>

<div class="form-page">
  <h1>Edit Thread</h1>
  <% if (error) { %><div class="error-msg"><%= error %></div><% } %>
  <form method="POST" action="<%= url('/threads/' + (thread.id) + '/edit') %>">
    <input type="hidden" name="_csrf" value="<%= csrfToken %>">
    <div class="form-group">
      <label for="title">Title</label>
      <input type="text" id="title" name="title" minlength="3" maxlength="120" required value="<%= thread.title %>">
    </div>
    <div class="form-group">
      <label for="body">Body</label>
      <textarea id="body" name="body" rows="10" maxlength="10000" required><%= thread.body %></textarea>
    </div>
    <% if (canModerateThread) { %>
      <%- include('../partials/reply-approval-trust-select') %>
      <fieldset class="moderation-fieldset">
        <legend>Visibility</legend>
        <div class="form-group">
          <label>
            <input type="checkbox" name="isHidden" value="1" <%= thread.isHidden ? 'checked' : '' %>>
            Hidden (staff can still see this thread)
          </label>
        </div>
        <div class="form-group">
          <label>
            <input type="checkbox" name="isDeleted" value="1" <%= thread.isDeleted ? 'checked' : '' %>>
            Deleted (soft-delete; removes from public lists)
          </label>
        </div>
        <div class="form-group">
          <label>
            <input type="checkbox" name="isLocked" value="1" <%= thread.isLocked ? 'checked' : '' %>>
            Locked (only moderators can reply or edit comments)
          </label>
        </div>
        <div class="form-group">
          <label>
            <input type="checkbox" name="embedEnabled" value="1" <%= thread.embedEnabled ? 'checked' : '' %>>
            Allow embedding (comment thread for external pages)
          </label>
        </div>
      </fieldset>
      <% if (thread.embedEnabled && typeof embedSnippet !== 'undefined' && embedSnippet) { %>
      <div class="form-group embed-snippet">
        <label class="embed-snippet-label">Embed link and iframe code</label>
        <%- include('../partials/embed-copy-fields') %>
        <p style="font-size:0.8rem;color:var(--color-text-muted);margin-top:0.25rem">
          <a href="<%= url('/embed/threads/' + (thread.id) + '') %>" target="_blank" rel="noopener">Preview embed</a>
        </p>
      </div>
      <% } %>
    <% } %>
    <button type="submit" class="btn">Save Changes</button>
    <a href="<%= url('/threads/' + (thread.id) + '') %>" class="btn btn-secondary">Cancel</a>
  </form>
</div>

<%- include('../partials/layout-bottom') %>

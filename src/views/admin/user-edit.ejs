<%- include('../partials/layout-top', { title: title }) %>

<div class="admin-page form-page" style="max-width:600px">
  <h1>Edit User</h1>
  <% if (error) { %><div class="error-msg"><%= error %></div><% } %>

  <p style="margin-bottom:1rem">
    <a href="<%= url('/admin/users/' + (profile.id) + '/profile') %>">Edit profile (username &amp; delete)</a>
    &middot;
    <a href="<%= url('/users/' + (profile.id) + '') %>">View public profile</a>
    &middot;
    <a href="<%= url('/admin') %>">Admin dashboard</a>
  </p>

  <div style="margin-bottom:1rem;padding:0.75rem;border:1px solid var(--color-border);background:var(--color-surface)">
    <strong><%= profile.username %></strong> &mdash; <%= profile.email %><br>
    <small>Role: <%= profile.role %> | Trust: <%= profile.trust %> | Created: <%- include('../partials/local-time', { value: profile.createdAt, mode: 'date' }) %></small>
  </div>

  <% if (isAdminUser) { %>
    <form method="POST" action="<%= url('/admin/users/' + (profile.id) + '/edit') %>">
      <input type="hidden" name="_csrf" value="<%= csrfToken %>">

      <div class="form-group">
        <label for="role">Role</label>
        <select name="role" id="role">
          <option value="user" <%= profile.role === 'user' ? 'selected' : '' %>>user</option>
          <option value="moderator" <%= profile.role === 'moderator' ? 'selected' : '' %>>moderator</option>
          <option value="admin" <%= profile.role === 'admin' ? 'selected' : '' %>>admin</option>
        </select>
      </div>

      <div class="form-group">
        <label for="trust">Trust</label>
        <select name="trust" id="trust">
          <option value="new" <%= profile.trust === 'new' ? 'selected' : '' %>>new</option>
          <option value="unknown" <%= profile.trust === 'unknown' ? 'selected' : '' %>>unknown</option>
          <option value="trusted" <%= profile.trust === 'trusted' ? 'selected' : '' %>>trusted</option>
          <option value="verified" <%= profile.trust === 'verified' ? 'selected' : '' %>>verified</option>
          <option value="banned" <%= profile.trust === 'banned' ? 'selected' : '' %>>banned</option>
        </select>
      </div>

      <div class="form-group">
        <label for="reason">Reason (optional)</label>
        <input type="text" id="reason" name="reason" maxlength="500" placeholder="Reason for change...">
      </div>

      <button type="submit" class="btn">Save Changes</button>
      <a href="<%= url('/admin') %>" class="btn btn-secondary">Cancel</a>
    </form>
  <% } else { %>
    <p class="empty-state">Only admins can edit user roles and trust.</p>
    <a href="<%= url('/admin') %>" class="btn btn-secondary">Back</a>
  <% } %>
</div>

<%- include('../partials/layout-bottom') %>

<%- include('../partials/layout-top', { title: title }) %>

<div class="admin-page form-page" style="max-width:800px">
  <h1>Review Thread</h1>
  <% if (error) { %><div class="error-msg"><%= error %></div><% } %>

  <div class="thread-preview" style="margin-bottom:1.5rem;padding:1rem;border:1px solid var(--color-border)">
    <h2 style="font-size:1rem;margin-bottom:0.5rem"><%= thread.title %></h2>
    <p style="font-size:0.8rem;color:var(--color-text-muted)">
      By <strong><%= thread.authorUsername %></strong> in <strong><%= thread.categoryName %></strong>
      &mdash; Status: <strong><%= thread.approvalStatus %></strong>
      <% if (thread.isHidden) { %> | <span class="badge badge-hidden">Hidden</span><% } %>
      <% if (thread.isDeleted) { %> | <span class="badge badge-deleted">Deleted</span><% } %>
    </p>
    <hr style="margin:0.75rem 0;border-color:var(--color-border)">
    <div style="white-space:pre-wrap;font-size:0.9rem"><%= thread.body %></div>
  </div>

  <form method="POST" action="/admin/threads/<%= thread.id %>/edit">
    <input type="hidden" name="_csrf" value="<%= csrfToken %>">

    <div class="form-group">
      <label for="categoryId">Category</label>
      <select name="categoryId" id="categoryId">
        <% categories.forEach(cat => { %>
        <option value="<%= cat.id %>" <%= cat.id === thread.categoryId ? 'selected' : '' %>>
          <%= cat.name %><% if (cat.isHidden) { %> (staff only)<% } %>
        </option>
        <% }) %>
      </select>
    </div>

    <div class="form-group">
      <label for="title">Title</label>
      <input type="text" id="title" name="title" value="<%= thread.title %>" minlength="3" maxlength="120">
    </div>

    <div class="form-group">
      <label for="body">Body</label>
      <textarea id="body" name="body" rows="8" maxlength="10000"><%= thread.body %></textarea>
    </div>

    <div class="form-group">
      <label for="approvalStatus">Approval Status</label>
      <select name="approvalStatus" id="approvalStatus">
        <option value="">&#8212; no change &#8212;</option>
        <option value="approved" <%= thread.approvalStatus === 'approved' ? 'selected' : '' %>>approved</option>
        <option value="unapproved" <%= thread.approvalStatus === 'unapproved' ? 'selected' : '' %>>unapproved</option>
        <option value="unknown" <%= thread.approvalStatus === 'unknown' ? 'selected' : '' %>>unknown</option>
      </select>
    </div>

    <div class="form-group">
      <label>
        <input type="checkbox" name="isHidden" value="1" <%= thread.isHidden ? 'checked' : '' %>> Hidden
      </label>
    </div>

    <div class="form-group">
      <label>
        <input type="checkbox" name="isDeleted" value="1" <%= thread.isDeleted ? 'checked' : '' %>> Deleted
      </label>
    </div>

    <div class="form-group">
      <label>
        <input type="checkbox" name="embedEnabled" value="1" <%= thread.embedEnabled ? 'checked' : '' %>> Allow embedding (comment thread for external pages)
      </label>
    </div>

    <% if (thread.embedEnabled) { %>
    <div class="form-group">
      <label>Embed snippet</label>
      <textarea readonly rows="3" style="width:100%;font-family:monospace;font-size:0.8rem" onclick="this.select()">&lt;iframe src=&quot;<%= embedUrl %>&quot; width=&quot;100%&quot; height=&quot;480&quot; style=&quot;border:0&quot; title=&quot;Comments&quot;&gt;&lt;/iframe&gt;</textarea>
      <p style="font-size:0.8rem;color:var(--color-text-muted);margin-top:0.25rem">
        <a href="/embed/threads/<%= thread.id %>" target="_blank" rel="noopener">Preview embed</a>
      </p>
    </div>
    <% } %>

    <div class="form-group">
      <label for="reason">Reason (optional, max 280 chars)</label>
      <input type="text" id="reason" name="reason" maxlength="280" placeholder="Moderation reason...">
    </div>

    <button type="submit" class="btn">Save Changes</button>
    <a href="/admin" class="btn btn-secondary">Cancel</a>
  </form>
</div>

<%- include('../partials/layout-bottom') %>

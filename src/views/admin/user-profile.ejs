<%- include('../partials/layout-top', { title: title }) %>

<div class="admin-page form-page" style="max-width:600px">
  <h1>Edit User Profile</h1>
  <p style="margin-bottom:1rem">
    <a href="<%= url('/users/' + (profile.id) + '') %>">View public profile</a>
    &middot;
    <a href="<%= url('/admin/users/' + (profile.id) + '/edit') %>">Role &amp; trust settings</a>
    &middot;
    <a href="<%= url('/admin') %>">Admin dashboard</a>
  </p>

  <% if (error) { %><div class="error-msg"><%= error %></div><% } %>
  <% if (success) { %><div class="success-msg"><%= success %></div><% } %>

  <div style="margin-bottom:1.5rem;padding:0.75rem;border:1px solid var(--color-border);background:var(--color-surface)">
    <strong><%= profile.username %></strong> &mdash; <%= profile.email %><br>
    <small>
      Role: <%= profile.role %> | Trust: <%= profile.trust %>
      | Created: <%= formatDate(profile.createdAt) %>
      <% if (profile.isDeleted) { %> | <strong style="color:var(--color-error)">Deleted</strong><% } %>
    </small>
  </div>

  <% if (profile.isDeleted) { %>
    <p class="empty-state">This account has been deleted. Username and posts are redacted.</p>
  <% } else { %>
    <% if (pendingUsernameRequest) { %>
      <div class="notice-msg" style="margin-bottom:1rem">
        User has a pending request to change username to
        <strong><%= pendingUsernameRequest.requestedUsername %></strong>
        (submitted <%= formatDate(pendingUsernameRequest.createdAt) %>).
        Saving a new username below will reject that request.
      </div>
    <% } %>

    <form method="POST" action="<%= url('/admin/users/' + (profile.id) + '/profile') %>">
      <input type="hidden" name="_csrf" value="<%= csrfToken %>">

      <div class="form-group">
        <label for="username">Username</label>
        <input type="text" id="username" name="username" value="<%= profile.username %>"
          pattern="^[A-Za-z0-9_]{3,24}$" maxlength="24" required>
        <small style="display:block;margin-top:0.25rem;color:var(--color-text-muted)">
          3–24 characters (letters, numbers, underscores). Applied immediately (no approval needed).
        </small>
      </div>

      <div class="form-group">
        <label for="reason">Reason (optional)</label>
        <input type="text" id="reason" name="reason" maxlength="500" placeholder="Reason for change...">
      </div>

      <button type="submit" class="btn">Save Username</button>
    </form>

    <hr style="margin:2rem 0;border-color:var(--color-border)">

    <h2 style="font-size:1rem;margin-bottom:0.75rem">Reset Password</h2>
    <p style="margin-bottom:0.75rem;color:var(--color-text-muted);font-size:0.85rem">
      Set a new password for this account. All active sessions for this user will be signed out.
    </p>
    <form method="POST" action="<%= url('/admin/users/' + (profile.id) + '/password') %>">
      <input type="hidden" name="_csrf" value="<%= csrfToken %>">
      <div class="form-group">
        <label for="password">New password</label>
        <input type="password" id="password" name="password" minlength="8" maxlength="128" required autocomplete="new-password">
      </div>
      <div class="form-group">
        <label for="confirmPassword">Confirm new password</label>
        <input type="password" id="confirmPassword" name="confirmPassword" minlength="8" maxlength="128" required autocomplete="new-password">
      </div>
      <div class="form-group">
        <label for="passwordReason">Reason (optional)</label>
        <input type="text" id="passwordReason" name="reason" maxlength="500" placeholder="Reason for password reset...">
      </div>
      <button type="submit" class="btn">Update Password</button>
    </form>

    <hr style="margin:2rem 0;border-color:var(--color-border)">

    <h2 style="font-size:1rem;margin-bottom:0.75rem;color:var(--color-error)">Delete Account</h2>
    <p style="margin-bottom:0.75rem;color:var(--color-text-muted);font-size:0.85rem">
      Permanently delete this account. Their posts remain but the username will show as
      <strong>[deleted]</strong>.
    </p>
    <% if (profile.id === currentAdminId) { %>
      <p class="notice-msg">You cannot delete your own account from here. Use Edit Profile instead.</p>
    <% } else { %>
      <form method="POST" action="<%= url('/admin/users/' + (profile.id) + '/delete') %>"
        onsubmit="return confirm('Permanently delete this user account?');">
        <input type="hidden" name="_csrf" value="<%= csrfToken %>">
        <div class="form-group">
          <label for="deleteReason">Reason (optional)</label>
          <input type="text" id="deleteReason" name="reason" maxlength="500" placeholder="Reason for deletion...">
        </div>
        <button type="submit" class="btn" style="background:var(--color-error)">Delete Account</button>
      </form>
    <% } %>
  <% } %>
</div>

<%- include('../partials/layout-bottom') %>

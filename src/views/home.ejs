<%- include('partials/layout-top', { title: title }) %>

<div class="forum-home">
  <% if (categories.length === 0) { %>
    <p class="empty-state">No categories yet.</p>
  <% } else { %>
    <% categories.forEach(function(cat) { %>
      <div class="category-block">
        <div class="category-header">
          <h2 class="category-name"><%= cat.name %></h2>
          <% if (cat.description) { %><p class="category-desc"><%= cat.description %></p><% } %>
          <% if (user && (user.role === 'admin' || user.role === 'moderator')) { %>
            <% if (cat.isHidden) { %><span class="badge badge-hidden">Hidden</span><% } %>
          <% } %>
        </div>
        <table class="thread-table">
          <thead>
            <tr>
              <th class="th-title">Thread</th>
              <th class="th-author">Author</th>
              <th class="th-replies">Replies</th>
              <th class="th-activity">Last Activity</th>
            </tr>
          </thead>
          <tbody>
            <% if (cat.recentThreads.length === 0) { %>
              <tr><td colspan="4" class="empty-row">No threads yet.<% if (user) { %> <a href="/threads/new?categoryId=<%= cat.id %>">Start one!</a><% } %></td></tr>
            <% } else { %>
              <% cat.recentThreads.forEach(function(thread) { %>
                <tr>
                  <td class="td-title">
                    <a href="/threads/<%= thread.id %>"><%= thread.title %></a>
                    <% if (user && (user.role === 'admin' || user.role === 'moderator')) { %>
                      <%- include('partials/status-badge', { item: thread }) %>
                    <% } %>
                  </td>
                  <td class="td-author"><a href="/users/<%= thread.authorUserId %>"><%= thread.authorUsername %></a></td>
                  <td class="td-replies"><%= thread.postCount %></td>
                  <td class="td-activity"><%= formatDate(thread.updatedAt) %></td>
                </tr>
              <% }); %>
            <% } %>
          </tbody>
        </table>
        <div class="category-actions">
          <% if (user) { %><a href="/threads/new?categoryId=<%= cat.id %>" class="btn btn-sm">+ New Thread</a><% } %>
        </div>
      </div>
    <% }); %>
  <% } %>
</div>

<%- include('partials/layout-bottom') %>

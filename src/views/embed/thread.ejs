<%- include('layout-top', { title: title }) %>

<div class="embed-shell"<% if (paddingStyle) { %> style="<%= paddingStyle %>"<% } %>>
  <div class="embed-thread thread-view" data-thread-id="<%= threadId %>" data-draft-key="<%= draftKey %>" data-auth-return-url="<%= authReturnUrl %>">
    <% if (notice) { %><div class="<%= notice.kind === 'success' ? 'success-msg' : 'notice-msg' %>"><%= notice.message %></div><% } %>
    <% if (error) { %><div class="error-msg"><%= error %></div><% } %>

    <div class="posts-section">
      <h2>Comments (<%= posts.total %>)</h2>

      <% if (posts.data.length === 0) { %>
        <p class="empty-state">No comments yet. Be the first to comment.</p>
      <% } else { %>
        <% posts.data.forEach(function(post) { %>
          <div class="post" id="post-<%= post.id %>">
            <div class="post-author">
              <%- include('../partials/avatar', { username: post.authorUsername }) %>
              <%- include('../partials/author-link', { authorUsername: post.authorUsername, authorUserId: post.authorUserId, authorIsDeleted: post.authorIsDeleted, authorTrust: post.authorTrust, plain: true }) %>
              <small><%= formatDate(post.createdAt) %></small>
              <% if (post.approvalStatus !== 'approved' && user && user.id === post.authorUserId) { %>
                <%- include('../partials/status-badge', { item: post }) %>
              <% } %>
            </div>
            <div class="post-body">
              <%- post.bodyHtml %>
              <%- include('../partials/edit-note', {
                createdAt: post.createdAt,
                lastEditedAt: post.lastEditedAt,
                editorUsername: post.editorUsername,
                lastEditedByUserId: post.lastEditedByUserId,
                editorIsDeleted: post.editorIsDeleted,
                plainAuthors: true,
              }) %>
            </div>
          </div>
        <% }); %>
      <% } %>

      <% if (posts.totalPages > 1) { %>
        <div class="pagination">
          <% if (page > 1) { %><a href="?page=<%= page - 1 %><%= paddingQuery ? '&' + paddingQuery : '' %>" class="btn btn-sm">&larr; Prev</a><% } %>
          <span>Page <%= page %> of <%= posts.totalPages %></span>
          <% if (page < posts.totalPages) { %><a href="?page=<%= page + 1 %><%= paddingQuery ? '&' + paddingQuery : '' %>" class="btn btn-sm">Next &rarr;</a><% } %>
        </div>
      <% } %>
    </div>

    <% if (thread.isLocked) { %>
      <p class="notice-msg">This thread is locked. New comments are disabled.</p>
    <% } %>

    <div class="reply-form">
      <% if (canPostToThread(!!thread.isLocked, user)) { %>
      <h3>Add a comment</h3>
      <form id="embed-compose-form" method="POST" action="<%= url('/embed/threads/' + (threadId) + '/posts') %>">
        <input type="hidden" name="_csrf" value="<%= csrfToken %>">
        <textarea id="embed-compose-body" name="body" rows="6" placeholder="Write your comment…" maxlength="<%= maxPostBodyLength %>"><%= body %></textarea>
        <div class="embed-compose-actions">
          <% if (user) { %>
            <button type="submit" class="btn">Post comment</button>
            <span class="embed-signed-in">Signed in as <%= user.username %></span>
          <% } else { %>
            <button type="submit" class="btn">Post comment</button>
            <button type="button" class="btn btn-secondary" id="embed-login-btn">Log in to post</button>
            <button type="button" class="btn btn-secondary" id="embed-register-btn">Create account</button>
          <% } %>
        </div>
      </form>
      <% } else if (thread.isLocked) { %>
      <p class="login-prompt">This thread is locked.</p>
      <% } %>
    </div>
  </div>

  <footer class="embed-powered-by">
    powered by <a href="<%= forumHomeUrl %>" target="_blank" rel="noopener noreferrer">forum-furiosum</a>
  </footer>
</div>

<%- include('layout-bottom') %>

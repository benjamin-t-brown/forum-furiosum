# Application
NODE_ENV=development
PORT=9827

# Subpath when behind a reverse proxy (no trailing slash). Leave empty at domain root.
BASE_PATH=

# Database
# Path to the SQLite database file
DB_PATH=./forum.sqlite

# Session
# A long random secret string for signing session cookies
SESSION_SECRET=change-this-to-a-long-random-secret

# Admin Bootstrap (required in production for first run)
# These credentials are used to create the initial admin account
# In development, defaults to admin@admin.com / test12345 if not set
# ADMIN_BOOTSTRAP_EMAIL=admin@yourdomain.com
# ADMIN_BOOTSTRAP_PASSWORD=change-this-to-a-strong-password
# ADMIN_BOOTSTRAP_USERNAME=admin

# Embed
# CSP frame-ancestors value for /embed/* routes (use * for dev, restrict in production)
EMBED_FRAME_ANCESTORS=*

# Moderation poll (optional) — enables GET /api/v1/internal/pending for external notifiers
MODERATION_POLL_SECRET=change-this-to-a-long-random-secret

# Public forum URL — used by embed snippets (include subpath) and scripts/notify.ts
FORUM_BASE_URL=http://localhost:9827
DISCORD_BOT_TOKEN=your-discord-bot-token
DISCORD_CHANNEL_ID=your-discord-channel-id
# NOTIFY_EVENT_TYPES=approval_required,comment_created,post_edited,post_deleted,thread_deleted,thread_created,user_created,user_role_changed,username_changed
# NOTIFY_INITIAL_LOOKBACK_MINUTES=1440
# NOTIFY_PRUNE_DAYS=90

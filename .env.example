# Application
NODE_ENV=development
PORT=9827

# Database
# Path to the SQLite database file
DB_PATH=./forum.sqlite

# Session
# A long random secret string for signing session cookies
SESSION_SECRET=change-this-to-a-long-random-secret

# Admin Bootstrap (required in production for first run)
# These credentials are used to create the initial admin account
# In development, defaults to admin@admin.com / test12345 if not set
ADMIN_BOOTSTRAP_EMAIL=admin@yourdomain.com
ADMIN_BOOTSTRAP_PASSWORD=change-this-to-a-strong-password
ADMIN_BOOTSTRAP_USERNAME=admin

# Embed
# CSP frame-ancestors value for /embed/* routes (use * for dev, restrict in production)
EMBED_FRAME_ANCESTORS=*

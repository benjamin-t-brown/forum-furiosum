{
  "name": "forum-furiosum",
  "version": "1.0.0",
  "description": "A simple old-school web forum",
  "main": "dist/index.js",
  "packageManager": "npm@11.17.0",
  "engines": {
    "node": ">=20",
    "npm": ">=11.17.0"
  },
  "allowScripts": {
    "argon2@0.41.1": true,
    "better-sqlite3@12.9.0": true,
    "esbuild": false,
    "fsevents": false
  },
  "scripts": {
    "start": "tsx watch src/index.ts",
    "prod": "tsc && node dist/index.js",
    "test": "vitest",
    "migrate": "tsx scripts/migrate.ts",
    "seed": "tsx scripts/seed-dev.ts --force",
    "notify": "tsx scripts/notify.ts",
    "notify:prod": "node dist/notify.js",
    "lint": "eslint src",
    "lint:fix": "eslint src --fix",
    "deps:check-scripts": "npm approve-scripts --allow-scripts-pending",
    "deps:check-no-git": "tsx scripts/check-no-git-deps.ts",
    "deps:check": "npm run deps:check-scripts && npm run deps:check-no-git"
  },
  "dependencies": {
    "argon2": "0.41.1",
    "better-sqlite3": "12.9.0",
    "cookie-parser": "1.4.7",
    "csurf": "1.11.0",
    "dotenv": "16.6.1",
    "ejs": "3.1.10",
    "express": "4.22.1",
    "express-rate-limit": "7.5.1",
    "express-session": "1.19.0",
    "linkifyjs": "4.3.2",
    "pino": "9.14.0",
    "pino-http": "10.5.0",
    "uuid": "11.1.1"
  },
  "devDependencies": {
    "@types/better-sqlite3": "7.6.13",
    "@types/cookie-parser": "1.4.10",
    "@types/ejs": "3.1.5",
    "@types/express": "5.0.6",
    "@types/express-session": "1.19.0",
    "@types/node": "22.19.18",
    "@types/supertest": "6.0.3",
    "@types/uuid": "10.0.0",
    "@typescript-eslint/eslint-plugin": "8.59.2",
    "@typescript-eslint/parser": "8.59.2",
    "eslint": "10.3.0",
    "pino-pretty": "13.1.3",
    "supertest": "7.2.2",
    "tsx": "4.21.0",
    "typescript": "5.9.3",
    "vitest": "3.2.4"
  }
}
